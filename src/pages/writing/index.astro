---
import { getCollection } from 'astro:content';
import dayjs from 'dayjs';
import PageTitle from '@/components/PageTitle.astro';
import Layout from '@/layouts/Layout.astro';
import '@/styles/global.css';

const posts = await getCollection('posts');
const sortedPosts = posts
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .map((post) => ({
    id: post.id,
    title: post.data.title,
    date: dayjs(post.data.date).format('MMMM D, YYYY'),
    tags: post.data.tags,
  }));
---

<Layout>
  <PageTitle>Writing</PageTitle>

  <div class="mx-auto grid max-w-2xl gap-4">
    {
      sortedPosts.map((post) => (
        <div class="grid gap-2">
          <a href={`/writing/${post.id}`}>
            <h3 class="text-lg">{post.title}</h3>
            <p class="text-sm font-medium text-gray-500">{post.date}</p>
          </a>

          <div>
            {post.tags.map((tag) => (
              <span class="mr-2 rounded bg-gray-200 px-2 py-1 text-xs font-medium text-gray-700">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Layout>
