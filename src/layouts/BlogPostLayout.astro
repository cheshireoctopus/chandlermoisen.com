---
import dayjs from 'dayjs';
import type { CollectionEntry } from 'astro:content';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import DarkModeToggle from '@/components/DarkModeToggle.astro';
import PageTitle from '@/components/PageTitle.astro';
import '@/styles/global.css';

interface Props {
  frontmatter: CollectionEntry<'posts'>['data'];
}

const { frontmatter } = Astro.props as Props;

const formattedDate = dayjs(frontmatter.date).format('MMMM D, YYYY');
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="icon"
      type="image/svg+xml"
      href='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><text x="0" y="24" font-size="24">🐙</text></svg>'
    />
    <title>{frontmatter.title}</title>

    <script is:inline>
      const theme = localStorage.getItem('theme');
      const query = window?.matchMedia('(prefers-color-scheme: dark)');

      if (theme) {
        document.documentElement.classList.add(theme);
      } else if (query?.matches) {
        document.documentElement.classList.add('dark');
      }

      query.addEventListener('change', (event) => {
        debugger;

        localStorage.clear('theme');

        if (event.matches) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      });
    </script>
  </head>

  <body class="dark:bg-gray-950 dark:text-white">
    <div
      class="mx-auto grid h-screen max-w-4xl grid-rows-[min-content_auto_min-content] px-4 md:px-2 lg:px-0"
    >
      <Header />

      <div class="mx-auto">
        <PageTitle>{frontmatter.title}</PageTitle>

        <div class="mb-10 text-center text-sm font-medium text-gray-400">
          {formattedDate}
        </div>

        <main class="prose dark:prose-invert mx-auto">
          <slot />
        </main>
      </div>

      <Footer />

      <DarkModeToggle />
    </div>
  </body>
</html>
