---
import '@/styles/global.css';

const { pathname } = Astro.url;

const linkClass = (href: string) =>
  pathname.includes(href)
    ? 'dark:text-gray-400 text-black underline'
    : 'dark:text-gray-400';
---

<div class="space-between flex items-center justify-between py-6">
  <div class="text-base font-semibold md:text-lg">
    <a href="/">Chandler Moisen</a>
  </div>

  <nav class="flex gap-4 text-sm font-medium">
    <a href="/experience" class={linkClass('/experience')} data-astro-prefetch
      >Experience</a
    >
    <a href="/writing" class={linkClass('/writing')} data-astro-prefetch
      >Writing</a
    >
    <a href="/about" class={linkClass('/about')} data-astro-prefetch>About</a>
  </nav>
</div>
